# === Anthropic ===
ANTHROPIC_API_KEY=sk-ant-...

# === OpenAI ===
OPENAI_API_KEY=sk-...

# === Universal override (takes priority over all above) ===
# AGENT_API_KEY=your-key-here

# === OpenAI-compatible service (Ollama, vLLM, polza.ai, etc.) ===
# AGENT_BASE_URL=https://api.polza.ai/v1

# === Agent settings ===
AGENT_MODEL=anthropic/claude-sonnet-4-6
AGENT_MAX_STEPS=50
AGENT_WORKING_DIR=.
AGENT_VERBOSE=true
AGENT_DISABLED_TOOLS=
